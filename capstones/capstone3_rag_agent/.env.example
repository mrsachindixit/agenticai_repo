# Example .env for capstone3_rag_agent (Ollama configuration)
# Configure a local Ollama instance endpoint and model names
OLLAMA_BASE=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_EMBED_MODEL=nomic-embed-text
# Chroma persistence directory (relative or absolute)
CHROMA_PERSIST_DIR=./chroma_db